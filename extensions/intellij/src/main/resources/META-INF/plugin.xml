<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.yutoagentic.yutoagenticintellijextension</id>
    <name>Yuto Agentic</name>
    <vendor url="https://yutoagentic.dev/">yutoagentic</vendor>
    <change-notes>
        <![CDATA[View the latest release notes on <a href="https://github.com/yutoagentic/yutoagentic/releases">GitHub</a>]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <!-- See here for why this is optional:  https://github.com/continuedev/continue/issues/2775#issuecomment-2535620877-->
    <depends optional="true" config-file="yutoagenticintellijextension-withJSON.xml">
        com.intellij.modules.json
    </depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="YutoAgentic" anchor="right" icon="com.github.yutoagentic.yutoagenticintellijextension.Icons.Continue"
                    factoryClass="com.github.yutoagentic.yutoagenticintellijextension.toolWindow.ContinuePluginToolWindowFactory"/>
        <projectService id="ContinuePluginService"
                        serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.services.ContinuePluginService"/>
        <projectService
                id="DiffStreamService"
                serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.editor.DiffStreamService"/>

        <projectService serviceInterface="com.github.yutoagentic.yutoagenticintellijextension.autocomplete.CompletionService"
                        serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.autocomplete.ContinueCompletionService"/>
        <projectService
                serviceInterface="com.github.yutoagentic.yutoagenticintellijextension.nextEdit.NextEditService"
                serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.nextEdit.ContinueNextEditService"/>

        <projectService
                serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.nextEdit.NextEditWindowManager"/>

        <projectService
                serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.nextEdit.NextEditJumpManager"/>

        <inline.completion.provider id="YutoAgentic" implementation="com.github.yutoagentic.yutoagenticintellijextension.autocomplete.ContinueInlineCompletionProvider"/>
        
        <notificationGroup id="YutoAgentic"
                           displayType="BALLOON"/>
        <actionPromoter order="last"
                        implementation="com.github.yutoagentic.yutoagenticintellijextension.actions.ContinueActionPromote"/>
        <postStartupActivity
                implementation="com.github.yutoagentic.yutoagenticintellijextension.activities.ContinuePluginStartupActivity"/>
        <postStartupActivity implementation="com.github.yutoagentic.yutoagenticintellijextension.proxy.ProxyPoolingActivity"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.github.yutoagentic.yutoagenticintellijextension.services.ContinueExtensionConfigurable"
                id="com.github.yutoagentic.yutoagenticintellijextension.services.ContinueExtensionConfigurable"
                displayName="Yuto Agentic"/>
        <applicationService
                serviceImplementation="com.github.yutoagentic.yutoagenticintellijextension.services.ContinueExtensionSettings"/>
    </extensions>

    <actions>
        <action class="com.github.yutoagentic.yutoagenticintellijextension.editor.InlineEditAction"
                id="yutoagentic.inlineEdit"
                description="Inline Edit"
                text="Inline Edit">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl I"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="meta I"/>
            <override-text place="GoToAction" text="Yuto Agentic: Edit Code"/>
        </action>

        <action id="yutoagentic.acceptDiff"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.AcceptDiffAction"
                text="Accept Diff" description="Accept Diff">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="shift ctrl ENTER"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="shift meta ENTER"/>
            <override-text place="GoToAction" text="Yuto Agentic: Accept Diff"/>
        </action>

        <action id="yutoagentic.restartProcess"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.RestartContinueProcess"
                text="Restart Process"
                description="Restart Process">
            <override-text place="GoToAction" text="Yuto Agentic: Restart Process"/>
        </action>

        <action id="yutoagentic.rejectDiff"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.RejectDiffAction"
                text="Reject Diff" description="Reject Diff">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="shift ctrl BACK_SPACE"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="shift meta BACK_SPACE"/>
            <override-text place="GoToAction" text="Yuto Agentic: Reject Diff"/>
        </action>

        <action id="yutoagentic.acceptVerticalDiffBlock"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.AcceptDiffAction"
                text="Accept Diff" description="Accept Vertical Diff Block">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="alt shift Y"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="alt shift Y"/>
            <override-text place="GoToAction" text="Yuto Agentic: Accept Vertical Diff Block"/>
        </action>

        <action id="yutoagentic.rejectVerticalDiffBlock"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.RejectDiffAction"
                text="Reject Diff" description="Reject Vertical Diff Block">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="alt shift N"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="alt shift N"/>
            <override-text place="GoToAction" text="Yuto Agentic: Reject Vertical Diff Block"/>
        </action>

        <action id="yutoagentic.addLicenseKey"
                class="com.github.yutoagentic.yutoagenticintellijextension.license.AddLicenseKey"
                text="Enter Enterprise License Key"
                description="Enter Enterprise License Key">
            <override-text place="GoToAction" text="Yuto Agentic: Enter Enterprise License Key"/>
        </action>

        <action id="yutoagentic.focusContinueInputWithoutClear"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.FocusContinueInputWithoutClearAction"
                text="Add selected code to context"
                description="Focus Yuto Agentic Input With Edit">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl shift J"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="meta shift J"/>
            <override-text place="GoToAction" text="Yuto Agentic: Add Highlighted Code to Context"/>
        </action>

        <action id="yutoagentic.newContinueSession"
                icon="AllIcons.General.Add"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.NewContinueSessionAction"
                text="New Session"
                description="New Session">

            <override-text place="GoToAction" text="New Session"/>
        </action>

        <action id="yutoagentic.viewHistory"
                icon="AllIcons.Vcs.History"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.ViewHistoryAction"
                text="View History"
                description="View History">
            <override-text place="GoToAction" text="View History"/>
        </action>

        <action id="yutoagentic.openConfigPage"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.OpenConfigAction"
                icon="AllIcons.General.GearPlain"
                text="Settings"
                description="Settings">
            <override-text place="GoToAction" text="Settings"/>
        </action>

        <action id="yutoagentic.reloadPage"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.ReloadBrowserAction"
                icon="AllIcons.Actions.Refresh"
                text="Reload Yuto Agentic Browser"
                description="Reload Yuto Agentic Browser">
            <override-text place="GoToAction" text="Reload Yuto Agentic Browser"/>
        </action>

        <action id="yutoagentic.openLogs"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.OpenLogsAction"
                icon="AllIcons.General.ShowInfos"
                text="Open Logs"
                description="Open Yuto Agentic Logs">
            <override-text place="GoToAction" text="Open Yuto Agentic Logs"/>
        </action>

        <group id="ContinueSidebarActionsGroup">
            <reference ref="yutoagentic.newContinueSession"/>
            <reference ref="yutoagentic.viewHistory"/>
            <reference ref="yutoagentic.openConfigPage"/>
            <reference ref="yutoagentic.reloadPage" />
        </group>

        <action id="yutoagentic.focusContinueInput"
                class="com.github.yutoagentic.yutoagenticintellijextension.actions.FocusContinueInputAction"
                text="Add selected code to context"
                description="Focus Yuto Agentic Input">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ctrl J"/>
            <keyboard-shortcut keymap="Mac OS X"
                               first-keystroke="meta J"/>
            <add-to-group group-id="EditorPopupMenu"/>
            <override-text place="GoToAction" text="Yuto Agentic: Add Highlighted Code to Context and Clear Chat"/>
        </action>
        <group id="ContinueProjectViewPopUpMenuGroup" popup="true" text="Yuto Agentic" icon="/icons/yutoagentic.svg">
            <action id="com.github.yutoagentic.yutoagenticintellijextension.actions.AddToChatAction"
                    class="com.github.yutoagentic.yutoagenticintellijextension.actions.AddToChatAction"
                    text="Add to Chat">
            </action>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
